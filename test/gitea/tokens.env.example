# Example tokens file — copy to tokens.env and fill in real values.
# Generated by docker/gitea-setup.sh (the real file is gitignored).
# Source before running Gitea smoke tests:
#   source test/gitea/tokens.env
#
# test-user  → proxy:test-user  → LITERAL /test-owner/test-repo  (PUSH)
# user2      → proxy:user2      → GLOB    /otherorg/*             (PUSH)
# user3      → proxy:user3      → REGEX   /test-owner/test-repo.* (PUSH)
# gitproxyadmin → no proxy mapping → identity-not-linked test
export GITEA_TESTUSER_TOKEN=""
export GITEA_USER2_TOKEN=""
export GITEA_USER3_TOKEN=""
export GITEA_ADMIN_TOKEN=""
