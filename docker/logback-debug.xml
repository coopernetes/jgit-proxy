<?xml version="1.0" encoding="UTF-8"?>
<!-- Debug logging profile for diagnosing OIDC/Spring Security issues.
     Mount this file and set JAVA_TOOL_OPTIONS in docker-compose.oidc.yml:

       volumes:
         - ./docker/logback-debug.xml:/app/conf/logback-debug.xml:ro
       environment:
         JAVA_TOOL_OPTIONS: -Dlogback.configurationFile=/app/conf/logback-debug.xml

     Remove both when done — this is very chatty.
-->
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{requestId}] [%X{sessionId}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="org.springframework.security" level="DEBUG"/>
    <logger name="org.springframework.web.client" level="DEBUG"/>
    <logger name="org.finos.gitproxy" level="DEBUG"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
